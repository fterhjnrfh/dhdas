<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:NewAvalonia.Views"
             xmlns:vm="using:NewAvalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
             x:Class="NewAvalonia.Views.DisplayControl2"
             x:DataType="vm:DisplayControl2ViewModel">
    <!-- 稳定的波形显示区域（Avalonia+SkiaSharp后端） -->
    <local:SKWaveformDisplay x:Name="skDisplay" DataContext="{Binding}" />
</UserControl>