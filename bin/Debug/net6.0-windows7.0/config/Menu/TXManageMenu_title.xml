<?xml version="1.0" encoding="utf-8"?>
<DHTest>
	<!--测量-->
	<Module type ="MeasureModule" id ="MeasureModuleAnalysis">
		<!--参数管理-->
		<menu id ="ParamModuleAnalysis" analysis="1">
			<toolbar>
				<Control id="NewParamFunc" switch="MeasureModule|ChnSetupModuleAnalysis|AnalogParamModuleAnalysis"/>
			</toolbar>
			<toolbar>
				<Control id="SaveParamFunc"/>
				<Control id="SaveToParamFunc"/>
				<Control id="SaveHardWareParamFunc"/>
				<Control id="SaveDefaultParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="LoadSecondAmpParamFunc"/>
				<Control id="LoadParamFunc" switch="MeasureModule|ChnSetupModuleAnalysis|AnalogParamModuleAnalysis"/>
				<Control id="RenameParamFunc"/>
				<Control id="DelParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="CopyParamFunc"/>
				<Control id="CutParamFunc"/>
				<Control id="PasteParamFunc"/>
			</toolbar>
		</menu>
		<!--通道设置-->
		<menu id ="ChnSetupModuleAnalysis" analysis ="0">
			<toolbar>
				<Control id="SaveParamFunc"/>
				<Control id="SaveToParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="AnalogParamModuleAnalysis" UserControl ="1"/>
				<Control id="TachoParamModuleAnalysis" UserControl ="1"/>
				<Control id="GPSParamModuleAnalysis" UserControl ="1"/>
				<Control id="CANParamModuleAnalysis" UserControl ="1"/>
				<Control id="CounterParamModuleAnalysis" UserControl ="1"/>
				<Control id="CalibrateParamModuleAnalysis" UserControl ="1"/>
			</toolbar>
		</menu>
		<!--算法设置-->
		<menu id ="MathSetupModuleAnalysis" analysis ="0">
			<toolbar>
				<Control id="SaveParamFunc"/>
				<Control id="SaveToParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="MathSelfDefineModuleAnalysis"/>
				<Control id="SpectrumMathModuleAnalysis"/>
				<Control id="CableMathModuleAnalysis"/>
				<Control id="OrderMathModuleAnalysis"/>
				<Control id="AcousticsMathModuleAnalysis"/>
				<Control id="AlarmMathModuleAnalysis"/>
				<Control id="FFTAlarmMathModuleAnalysis"/>
				<Control id="StrainAlarmMathModuleAnalysis"/>
			</toolbar>
		</menu>
		<!--存储规则-->
		<menu id ="StoreModuleAnalysis" analysis ="0">
			<toolbar>
				<Control id="SaveParamFunc"/>
				<Control id="SaveToParamFunc"/>
			</toolbar>
		</menu>
		<menu id ="MeasureModuleAnalysis" analysis ="0">
			<toolbar>
				<Control id="MeasureStoreFunc"/>
				<Control id="MeasurePauseFunc"/>
				<Control id="MeasureRebackDataFunc"/>
				<Control id="MeasureContinueFunc"/>
				<Control id="MeasureStopFunc"/>
				<Control id="MeasureShiBoFunc"/>
				<Control id="MeasureTrigFunc"/>
				<Control id="MeasureBalanceZero"/>
				<Control id="MeasureTagFunc"/>
			</toolbar>
			<!--<toolbar>
        <Control id="AnalogChannelWindowFunc"/>
      </toolbar>-->
			<toolbar>
				<Control id="DelAllChatFunc"/>
				<Control id="DelChatFunc"/>
				<Control id="ChatHorizFunc"/>
				<Control id="ChatVertFunc"/>
			</toolbar>
			<toolbar>
				<Control id="MultiScreenFunc"/>
				<Control id="MultiScreenLayOutMgrFunc"/>
			</toolbar>
			<toolbar>
				<Control id="ChartGroupbuttonAnalysis" chartMenu="TXManageMenu_chart.xml" type="Chart"/>
			</toolbar>
			<toolbar>
				<Control id="RunInfoFunc"/>
			</toolbar>
		</menu>
	</Module>
	<!--分析-->
	<Module type ="AnalysisModule" id ="AnalysisModuleAnalysis">
		<!--通道-->
		<menu id ="ChannelModuleAnalysis" analysis ="1">
			<toolbar>
				<Control id="EditChannelFunc"/>
			</toolbar>
		</menu>
		<!--事件-->
		<menu id ="EventModuleAnalysis" analysis ="1">
			<toolbar>
				<Control id="AddEventFunc"/>
				<Control id="EditEventFunc"/>
				<Control id="DelEventFunc"/>
			</toolbar>
		</menu>
		<menu id ="MathSetupModuleAnalysis" analysis ="1">
			<toolbar>
				<Control id="MathSaveCurrentAlgParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="MathSelfDefineModuleAnalysis"/>
				<Control id="SpectrumMathModuleAnalysis"/>
				<Control id="CableMathModuleAnalysis"/>
				<Control id="OrderMathModuleAnalysis"/>
				<Control id="StableMathModuleAnalysis"/>
				<Control id="AcousticsMathModuleAnalysis"/>
				<Control id="FatigueMathModuleAnalysis"/>
				<Control id="AlarmMathModuleAnalysis"/>
