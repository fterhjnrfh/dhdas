			<toolbar>
				<Control id="NewPrjFunc" switch="MeasureModule|ChnSetupModuleAnalysis"/>
			</toolbar>
			<toolbar>
				<Control id="OpenPrjFunc" switch="AnalysisModule|AnalysisModuleAnalysis"/>
