<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:DH.Client.App.Views"
             x:Class="DH.Client.App.Views.ChannelSelector">
  
  <!-- 通道选择器设计 -->
  <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="5">
    
    <!-- 在线状态显示 -->
    <Border Grid.Row="0" Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,8">
      <TextBlock Name="OnlineStatusText" Text="在线通道: 0/0" FontSize="12" Foreground="#CCCCCC" HorizontalAlignment="Center"/>
    </Border>
    
    <!-- 选择模式切换 -->
    <Border Grid.Row="1" Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,8">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
        <RadioButton Name="SingleModeRadio" GroupName="SelectMode" Content="单选模式" 
                     Foreground="White" FontSize="12" IsChecked="True"/>
        <RadioButton Name="MultiModeRadio" GroupName="SelectMode" Content="叠加模式（多选）" 
                     Foreground="White" FontSize="12"/>
      </StackPanel>
    </Border>
    
    <!-- 视图通道选择区域 -->
    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Padding="8">
      <StackPanel>
        <TextBlock Text="通道选择" FontWeight="Bold" FontSize="12" Foreground="White" Margin="0,0,0,5"/>
        
        <!-- 控制按钮 -->
        <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,8">
          <Button Grid.Column="0" Name="ViewSelectAllButton" Content="全选" 
                  Margin="2" Padding="6,3" FontSize="11" Background="#4A4A4A" Foreground="White"/>
          <Button Grid.Column="1" Name="ViewClearAllButton" Content="清空" 
                  Margin="2" Padding="6,3" FontSize="11" Background="#4A4A4A" Foreground="White"/>
          <Button Grid.Column="2" Name="ViewInvertButton" Content="反选" 
                  Margin="2" Padding="6,3" FontSize="11" Background="#4A4A4A" Foreground="White"/>
        </Grid>
        
        <!-- 搜索框 -->
        <TextBox Name="SearchBox" Watermark="搜索通道..." 
                 Margin="0,0,0,8" FontSize="12" Background="#3A3A3A" Foreground="White"/>
        
        <!-- 通道列表 - 垂直排列 -->
        <ScrollViewer Height="300" VerticalScrollBarVisibility="Auto">
          <ItemsControl Name="ChannelList">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Vertical"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="views:ChannelItem">
                <CheckBox Content="{Binding DisplayText}" 
                          IsChecked="{Binding IsSelected}"
                          Foreground="{Binding TextBrush}"
                          Margin="2,1"
                          FontSize="12"
                          HorizontalAlignment="Stretch"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </StackPanel>
    </Border>
    
    <!-- 状态显示 -->
    <TextBlock Grid.Row="3" Name="ViewStatusText" 
               Text="已选择: 0 个通道" 
               HorizontalAlignment="Center" 
               Margin="0,8,0,0"
               FontSize="10"
               Foreground="#CCCCCC"/>
  </Grid>
</UserControl>