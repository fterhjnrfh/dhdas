	<!--工程管理-->
	<Module type ="ProjectModule" id ="ProjectModuleAnalysis">
		<menu id ="ProjectModuleAnalysis" analysis="1">
			<toolbar>
				<Control id="NewPrjFunc" switch="BSWAInstrumentModule|BSWAInstrumentModuleAnalysis"/>
			</toolbar>
			<toolbar>
				<Control id="OpenPrjFunc" switch="AnalysisModule|AnalysisModuleAnalysis"/>
				<Control id="RenamePrjFunc"/>
				<Control id="DelPrjFunc"/>
			</toolbar>
		</menu>
	</Module>
	
	<!--设备管理-->
	<Module type ="BSWAInstrumentModule" id ="BSWAInstrumentModuleAnalysis">
		<menu id ="BSWAInstrumentModuleAnalysis" analysis="1">
			<toolbar/>
		</menu>
	</Module>

