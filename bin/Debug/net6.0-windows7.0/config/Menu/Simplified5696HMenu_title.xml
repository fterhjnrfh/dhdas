<?xml version="1.0" encoding="utf-8" ?>
<DHTest>
	<!--工程管理-->
	<Module type ="ProjectModule" id ="ProjectModuleAnalysis" Default="1">
		<menu id ="ProjectModuleAnalysis" analysis="1">
			<toolbar>
				<Control id="NewPrjFunc" switch="MeasureModule|ChnSetupModuleAnalysis"/>
			</toolbar>
			<toolbar>
				<Control id="OpenPrjFunc" switch="AnalysisModule|AnalysisModuleAnalysis"/>
				<Control id="RenamePrjFunc"/>
				<Control id="DelPrjFunc"/>
			</toolbar>
		</menu>
	</Module>
	<!--测量-->
	<Module type ="MeasureModule" id ="MeasureModuleAnalysis">
		<!--参数管理-->
		<menu id ="ParamModuleAnalysis" analysis="1">
			<toolbar>
				<Control id="SaveParamFunc"/>
				<Control id="SaveToParamFunc"/>
				<Control id="SaveHardWareParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="LoadSecondAmpParamFunc"/>
				<Control id="LoadParamFunc" switch="MeasureModule|MeasureModuleAnalysis"/>
				<Control id="RenameParamFunc"/>
				<Control id="DelParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="CopyParamFunc"/>
				<Control id="CutParamFunc"/>
				<Control id="PasteParamFunc"/>
			</toolbar>
		</menu>
		<!--通道设置-->
		<menu id ="ChnSetupModuleAnalysis" analysis ="0">
			<toolbar>
				<Control id="SaveParamFunc"/>
				<Control id="SaveToParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="AnalogParamModuleAnalysis" UserControl ="1"/>
			</toolbar>
		</menu>
		<!--存储规则-->
		<menu id ="StoreModuleAnalysis" analysis ="0">
			<toolbar>
				<Control id="SaveParamFunc"/>
				<Control id="SaveToParamFunc"/>
			</toolbar>
		</menu>
		<!--算法设置-->
		<menu id ="MathSetupModuleAnalysis" analysis ="0">
			<toolbar>
				<Control id="SaveParamFunc"/>
				<Control id="SaveToParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="MathSelfDefineModuleAnalysis"/>
				<Control id="NewStrainAlarmMathModuleAnalysis"/>
			</toolbar>
		</menu>
		<!--测量-->
		<menu id ="MeasureModuleAnalysis" analysis ="0">
			<toolbar>
				<Control id="MeasureStoreFunc"/>
				<Control id="MeasurePauseFunc"/>
				<Control id="MeasureRebackDataFunc"/>
				<Control id="MeasureContinueFunc"/>
				<Control id="MeasureStopFunc"/>
				<Control id="MeasureShiBoFunc"/>
				<Control id="MeasureTrigFunc"/>
				<Control id="MeasureFreezeFunc"/>
			</toolbar>
			<toolbar>
				<Control id="MeasureAlarmControlFunc"/>
			</toolbar>
			<toolbar>
				<Control id="DelAllChatFunc"/>
				<Control id="DelChatFunc"/>
				<Control id="ChatHorizFunc"/>
				<Control id="ChatVertFunc"/>
			</toolbar>
			<toolbar>
				<Control id="LayoutGroupbuttonAnalysis" chartMenu="Commonmenu_chart.xml" type="Layout"/>
			</toolbar>
			<toolbar>
				<Control id="ChartGroupbuttonAnalysis" chartMenu="Commonmenu_chart.xml" type="Chart"/>
			</toolbar>
			<toolbar>
				<Control id="RunInfoFunc"/>
			</toolbar>
		</menu>

	</Module>
	
	<!--分析-->
	<Module type ="AnalysisModule" id ="AnalysisModuleAnalysis">
		<!--通道-->
		<menu id ="ChannelModuleAnalysis" analysis ="1">
			<toolbar>
				<Control id="EditChannelFunc"/>
			</toolbar>
		</menu>
		<!--事件-->
		<menu id ="EventModuleAnalysis" analysis ="1">
			<toolbar>
				<Control id="AddEventFunc"/>
				<Control id="EditEventFunc"/>
				<Control id="DelEventFunc"/>
			</toolbar>
		</menu>
		<menu id ="MathSetupModuleAnalysis" analysis ="1">
			<toolbar>
				<Control id="MathSaveCurrentAlgParamFunc"/>
				<Control id="MathSFUpDateParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="SaveAlgorithmParamFunc"/>
				<Control id="LoadAlgorithmParamFunc"/>
			</toolbar>
			<toolbar>
				<Control id="MathSelfDefineModuleAnalysis"/>
				<!--<Control id="GeneralMathModuleAnalysis"/>-->
				<Control id="SpectrumMathModuleAnalysis"/>
				<Control id="CableMathModuleAnalysis"/>
				<Control id="OrderMathModuleAnalysis"/>
				<Control id="NewOrderMathModuleAnalysis"/>
				<Control id="TorsionalVibrationModuleAnalysis"/>
				<Control id="TorVibMathModuleAnalysis"/>
				<Control id="StableMathModuleAnalysis"/>
				<Control id="AcousticsMathModuleAnalysis"/>
				<Control id="FatigueMathModuleAnalysis"/>
				<Control id="AlarmMathModuleAnalysis"/>
				<Control id="ShakeMathModuleAnalysis"/>
				<Control id="TorqueTransRateMathModuleAnalysis"/>
				<Control id="RainFlowMathModuleAnalysis"/>
				<Control id="ETCCurrentMathModuleAnalysis"/>
				<Control id="MedicineBurnMathModuleAnalysis"/>
				<Control id="ShockMathModuleAnalysis"/>
				<Control id="WindSpeedMathModuleAnalsyis"/>
				<Control id="MeasureMathModuleAnalysis"/>

			</toolbar>
		</menu>
		<menu id ="AnalysisModuleAnalysis" analysis ="1" Default="1">
			<toolbar>
				<Control id="AnalysisSaveAllParamFunc"/>
				<Control id="AnalysisExportTestFunc"/>
				<Control id="AnalysisSFLoadAlgorithmChatParam"/>
				<!--<Control id="AnalysisExportHitdmsFunc"/>-->
			</toolbar>
			<toolbar>
				<Control id="AnalysisStartPlaybackFunc"/>
				<Control id="MeasureTagFunc"/>
			</toolbar>
			<toolbar>
				<Control id="AnalysisHandCalFunc"/>
				<!--<Control id="AnalysisOutputRunData"/>-->
			</toolbar>
			<toolbar>
				<Control id="DelAllChatFunc"/>
				<!--<Control id="DelCurrentPageChatFunc"/>-->
				<Control id="DelChatFunc"/>
				<Control id="ChatHorizFunc"/>
				<Control id="ChatVertFunc"/>
			</toolbar>
			<toolbar>
				<Control id="MultiScreenFunc"/>
				<Control id="MultiScreenLayOutMgrFunc"/>
			</toolbar>
			<toolbar>
				<Control id="AnalysisShowWaveleteVibrateChart"/>
				<Control id="AnalysisOutDataTrigSetting"/>
			</toolbar>
			<toolbar>
				<Control id="LayoutGroupbuttonAnalysis" chartMenu="Commonmenu_chart.xml" type="Layout"/>
			</toolbar>
			<toolbar>
				<Control id="DesignModeFunc"/>
			</toolbar>
			<toolbar>
				<Control id="ChartGroupbuttonAnalysis" chartMenu="Commonmenu_chart.xml" type="Chart"/>
			</toolbar>
			<toolbar>
				<Control id="RunInfoFunc"/>
			</toolbar>
		</menu>
	</Module>

	<!--切换定义-->
	<Switch>
		<SwitchItem id="SwitchMeasurePath" path="MeasureModule|MeasureModuleAnalysis"></SwitchItem>
		<SwitchItem id="SwitchAnalysisPath" path="AnalysisModule|AnalysisModuleAnalysis"></SwitchItem>
		<SwitchItem id="SwitchChnAnalogPath" path="MeasureModule|ChnSetupModuleAnalysis|AnalogParamModuleAnalysis"></SwitchItem>
		<SwitchItem id="SwitchStorePath" path="MeasureModule|StoreModuleAnalysis"></SwitchItem>
		<SwitchItem id="SwitchProjectPath" path="ProjectModule|ProjectModuleAnalysis"></SwitchItem>
	</Switch>
</DHTest>