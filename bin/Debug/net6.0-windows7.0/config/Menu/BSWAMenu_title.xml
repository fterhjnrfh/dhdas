			<toolbar>
				<Control id="ChartGroupbuttonAnalysis" chartMenu="BSWAMenu_chart.xml" type="Chart"/>
			</toolbar>
			<toolbar>
				<Control id="RunInfoFunc"/>
			</toolbar>
		</menu>
