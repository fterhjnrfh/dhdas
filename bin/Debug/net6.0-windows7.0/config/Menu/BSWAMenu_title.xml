			</toolbar>
			<toolbar>
				<Control id="LayoutGroupbuttonAnalysis" chartMenu="BSWAMenu_chart.xml" type="Layout"/>
			</toolbar>
			<toolbar>
				<Control id="DesignModeFunc"/>
			</toolbar>
			<toolbar>
				<Control id="ChartGroupbuttonAnalysis" chartMenu="BSWAMenu_chart.xml" type="Chart"/>
