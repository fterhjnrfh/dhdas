<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="20" d:DesignHeight="20"
             x:Class="NewAvalonia.Views.ConnectionPointView"
             Width="20" Height="20">
    
    <UserControl.Styles>
        <Style Selector="Ellipse.connectionPoint">
            <Setter Property="Fill" Value="Blue"/>
            <Setter Property="Stroke" Value="DarkBlue"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
        </Style>
        
        <Style Selector="Ellipse.connectionPoint:pointerover">
            <Setter Property="Fill" Value="LightBlue"/>
            <Setter Property="Stroke" Value="Blue"/>
            <Setter Property="StrokeThickness" Value="3"/>
        </Style>
        
        <Style Selector="Ellipse.connectionPoint.connecting">
            <Setter Property="Fill" Value="Red"/>
            <Setter Property="Stroke" Value="DarkRed"/>
            <Setter Property="StrokeThickness" Value="3"/>
        </Style>
        
        <Style Selector="Ellipse.connectionPoint.connected">
            <Setter Property="Fill" Value="Green"/>
            <Setter Property="Stroke" Value="DarkGreen"/>
            <Setter Property="StrokeThickness" Value="2"/>
        </Style>
    </UserControl.Styles>
    
    <Grid>
        <Ellipse Name="connectionPoint" 
                 Classes="connectionPoint"
                 HorizontalAlignment="Center" 
                 VerticalAlignment="Center"
                 Cursor="Hand"/>
    </Grid>
</UserControl>